SECRET_KEY=change-me

# Supabase Session Pooler for project tutormanagement.
# Replace YOUR_SUPABASE_DB_PASSWORD with the database password from Supabase.
# You can use DATABASE_URL instead of the db_* fields below after replacing the password.
# DATABASE_URL=postgres://postgres.qxduegftklpdvhbdrjlj:YOUR_SUPABASE_DB_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
PGSSLMODE=require

# Legacy fallback used only when DATABASE_URL is not set.
db_user=postgres.qxduegftklpdvhbdrjlj
db_host=aws-1-ap-south-1.pooler.supabase.com
db_database=postgres
db_password=YOUR_SUPABASE_DB_PASSWORD
db_port=5432
DB_SSL=true
